{
  "name": "md-html-reader",
  "version": "0.9.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:dmg": "scripts/build-dmg-headless.sh",
    "tauri:build:dmg:tauri": "tauri build --bundles dmg",
    "smoke:dmg": "scripts/smoke-dmg-install.sh",
    "release:notarize": "scripts/sign-notarize-dmg.sh",
    "manual:prepare": "scripts/prepare-manual-acceptance.sh",
    "test": "vitest",
    "test:e2e": "pnpm run test:e2e:build && pnpm run test:e2e:core && pnpm run test:e2e:reopen",
    "test:e2e:build": "tauri build --debug --features e2e --bundles app --config src-tauri/tauri.e2e.conf.json",
    "test:e2e:core": "node scripts/run-e2e.mjs ./test/e2e/app.spec.ts",
    "test:e2e:reopen": "E2E_REOPEN_PHASE=create node scripts/run-e2e.mjs ./test/e2e/reopen.spec.ts && E2E_REOPEN_PHASE=verify node scripts/run-e2e.mjs ./test/e2e/reopen.spec.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@milkdown/core": "^7.5.0",
    "@milkdown/ctx": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-prism": "^7.5.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/prose": "^7.5.0",
    "@milkdown/theme-nord": "^7.5.0",
    "@milkdown/vue": "^7.5.0",
    "@tauri-apps/api": "^2.3.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "pinia": "^2.2.0",
    "prismjs": "^1.29.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/native-utils": "2.5.0",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^13.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.0"
  }
}
